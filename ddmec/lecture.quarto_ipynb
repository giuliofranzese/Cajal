        "## Experiments\n",
        "\n",
        "### Gene Regulatory Network\n"
      ],
      "id": "781e12dc"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def simulate_grn(n_genes=5, T=500, dt=0.1, connectivity=None):\n",
        "    \"\"\"\n",
        "    Simulate a small gene regulatory network.\n",
        "\n",
        "    Dynamics: dx_i/dt = sum_j W_ij * sigma(x_j) - gamma * x_i + noise\n",
        "    \"\"\"\n",
        "    if connectivity is None:\n",
        "        connectivity = np.random.randn(n_genes, n_genes) * 0.3\n",
        "\n",
        "    trajectory = np.zeros((T, n_genes))\n",
        "    trajectory[0] = np.random.randn(n_genes)\n",
        "\n",
        "    for t in range(1, T):\n",
        "        x = trajectory[t - 1]\n",
        "        dx = connectivity @ (1 / (1 + np.exp(-x))) - 0.5 * x\n",
        "        trajectory[t] = x + dt * dx + 0.1 * np.sqrt(dt) * np.random.randn(n_genes)\n",
        "\n",
        "    return trajectory\n",
        "\n",
        "traj = simulate_grn(n_genes=5, T=1000)\n",
        "# TODO: run DD-mec pipeline on this simulated GRN\n",
        "pass"
      ],
