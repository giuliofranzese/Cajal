%-----------------------------------------------------------
% Define a whole bunch of custom colours and fonts
%-----------------------------------------------------------


\definecolor{lgreen} {RGB}{180,210,100}
\definecolor{dblue}  {RGB}{20,66,129}
\definecolor{ddblue} {RGB}{11,36,69}
\definecolor{lred}   {RGB}{220,0,0}
\definecolor{nred}   {RGB}{224,0,0}
\definecolor{norange}{RGB}{230,120,20}
\definecolor{nyellow}{RGB}{255,221,0}
\definecolor{ngreen} {RGB}{98,158,31}
\definecolor{dgreen} {RGB}{78,138,21}
\definecolor{nblue}  {RGB}{28,130,185}
\definecolor{jblue}  {RGB}{20,50,100}


\definecolor{conferenceBlueDark}{RGB}{11,36,69}
\definecolor{conferenceBlueMid}{RGB}{11,36,69}
\definecolor{conferenceBlueLight}{RGB}{11,36,69}

\definecolor{conferenceRed}{RGB}{230,120,20}
\definecolor{conferenceRedDark}{RGB}{230,120,20}
\definecolor{conferenceRedLight}{RGB}{230,120,20}

\definecolor{conferenceBlue2Dark}{HTML}{1d4442} 
\definecolor{conferenceBlue2Mid}{HTML}{43aaa0} 
\definecolor{conferenceBlue2Light}{HTML}{d4f3ed} 

\definecolor{conferenceOrange}{RGB}{252, 198, 3}
\definecolor{conferenceOrangeLight}{RGB}{252, 198, 3}

\definecolor{conferenceMint}{RGB}{78,138,21}

\definecolor{conferenceAntracite}{HTML}{282b34}


% set the basic colors
\setbeamercolor{palette primary}   {fg=conferenceBlueDark,bg=white}
\setbeamercolor{palette secondary} {fg=black,bg=white}
\setbeamercolor{palette tertiary}  {bg=jblue,fg=white}
\setbeamercolor{palette quaternary}{fg=black,bg=white}
\setbeamercolor{structure}{fg=jblue}
\setbeamercolor{titlelike}         {bg=jblue,fg=white}
\setbeamercolor{frametitle}        {bg=jblue!10,fg=jblue}
\setbeamercolor{cboxb}{fg=black,bg=conferenceBlueDark}
\setbeamercolor{cboxr}{fg=black,bg=red}
\setbeamercolor{title in headline}{fg=conferenceBlueDark}

% set colors for itemize/enumerate
\setbeamercolor{item}{fg=jblue}
\setbeamercolor{item projected}{fg=white,bg=jblue}

% set colors for blocks
% \setbeamercolor{block title}{fg=ngreen,bg=white}
% \setbeamercolor{block body}{fg=black,bg=white}
\setbeamercolor{block title}{fg=white,bg=conferenceBlueDark}
\setbeamercolor{block body}{fg=black,bg=conferenceBlueDark!20}

% set colors for alerted blocks (blocks with frame)
\setbeamercolor{block alerted title}{fg=white,bg=conferenceRed}
\setbeamercolor{block alerted body}{fg=black,bg=conferenceRed!20}

\setbeamercolor{block example title}{fg=white,bg=conferenceOrange}
\setbeamercolor{block example body}{fg=black,bg=conferenceOrange!20}

% set the fonts
\setbeamerfont{section in head/foot}{series=\bfseries}
\setbeamerfont{block title}{series=\bfseries}
\setbeamerfont{block alerted title}{series=\bfseries}
\setbeamerfont{frametitle}{series=\bfseries}
\setbeamerfont{frametitle}{size=\Large}

% set some beamer theme options
\setbeamertemplate{title page}[default][colsep=-4bp,rounded=true]
\setbeamertemplate{sections/subsections in toc}[square]
\setbeamertemplate{items}[circle]
\setbeamertemplate{blocks}[width=0.0]
\beamertemplatenavigationsymbolsempty

% set bibliography style
\setbeamertemplate{bibliography item}[text]
\setbeamercolor{bibliography item}{fg=black,bg=white}
\setbeamercolor{bibliography entry author}{fg=black,bg=white}
\setbeamercolor{bibliography item}{fg=black,bg=white}
 
\AtBeginEnvironment{block}{\setbeamercolor{itemize item}{fg=conferenceBlueDark}}
\AtBeginEnvironment{alertblock}{\setbeamercolor{itemize item}{fg=conferenceRed}
                                \setbeamercolor{itemize subitem}{fg=conferenceRed!80!black}}
\AtBeginEnvironment{exampleblock}{\setbeamercolor{itemize item}{fg=conferenceOrange}}
\AtBeginEnvironment{block}{\setbeamercolor{enumerate item}{fg=conferenceBlueDark}}
\AtBeginEnvironment{alertblock}{\setbeamercolor{enumerate item}{fg=conferenceRed}}
\AtBeginEnvironment{exampleblock}{\setbeamercolor{enumerate item}{fg=conferenceOrange}}
% define some length variables that are used by the template
\newlength{\inboxwd}
\newlength{\iinboxwd}
\newlength{\inboxrule}
\makeatletter
\makeatother

%==============================================================================
% build the poster title
%==============================================================================
\setbeamertemplate{headline}{
 \leavevmode
  \begin{columns}
   \begin{column}{.1\textwidth}
    \centering
    \includegraphics[scale=2.0]{assets/logo/ICLR2023.png}
   \end{column}
   \begin{column}{.75\linewidth}
    \vskip0.5cm
    \centering
    \usebeamercolor{title in headline}{\color{fg} \textbf{\veryHuge{\inserttitle}}\\[2ex]} 
    \vskip0.2cm
    \usebeamercolor{author in headline}{
      \usebeamerfont{author in headline}{
        \color{fg} \Large{\insertauthor}
        }\\[.5ex]}
    % check if institute is empty
    \ifx\insertinstitute\empty
    \else
     \usebeamercolor{institute in headline}{
      \usebeamerfont{institute in headline}{
      \color{fg} \large{\insertinstitute}\\[.25ex]
      }
    }
    \fi
    \vskip0.8cm
   \end{column}
   \begin{column}{.15\linewidth}
    \includegraphics[width=.95\textwidth]{assets/logo/eurecom.png} 
   \end{column}
   \vspace{0.8cm}
  \end{columns}
 \vspace{0.3in}
 \begin{beamercolorbox}[wd=\paperwidth,colsep=0.15cm]{cboxb}\end{beamercolorbox}
 \vspace{-0.3in}
}

